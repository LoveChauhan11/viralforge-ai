# Copy to .env for local development. Values below are non-secret examples.
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=debug
PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# PostgreSQL and Redis
DATABASE_URL=postgresql://viralforge:viralforge@localhost:5432/viralforge
REDIS_URL=redis://localhost:6379

# S3-compatible object storage (MinIO locally)
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=viralforge-local
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Local auth adapter
AUTH_PROVIDER=fake
AUTH_SESSION_SECRET=replace-with-at-least-32-local-characters

# AI/provider selection. Fake adapters require no external credentials.
MODEL_PROVIDER=fake
TRANSCRIPTION_PROVIDER=fake
TREND_PROVIDER=fake
YOUTUBE_PROVIDER=fake
OPENAI_API_KEY=

# YouTube OAuth — optional until real integration testing
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:4000/v1/integrations/youtube/callback
YOUTUBE_WEBHOOK_SECRET=

# Media and job safety limits
MAX_UPLOAD_BYTES=5368709120
MAX_PROJECT_ASSETS=100
MEDIA_JOB_TIMEOUT_SECONDS=3600
AI_JOB_TIMEOUT_SECONDS=300
SIGNED_URL_TTL_SECONDS=900

# Telemetry
OTEL_SERVICE_NAME=viralforge
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# Email/notifications — fake locally
NOTIFICATION_PROVIDER=fake
EMAIL_FROM=no-reply@example.invalid

# Railway injects PORT. Keep a local default only.
PORT=4000
