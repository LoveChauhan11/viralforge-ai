# Copy to .env for local development. Values below are non-secret examples.
NODE_ENV=development
APP_ENV=local
LOG_LEVEL=debug
PUBLIC_WEB_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
API_ORIGIN=http://localhost:4000
SERVICE_NAME=viralforge-local

# PostgreSQL and Redis
DATABASE_URL=postgresql://viralforge:viralforge@localhost:5432/viralforge
REDIS_URL=redis://localhost:6379

# S3-compatible object storage (MinIO locally)
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=viralforge-local
OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
OBJECT_STORAGE_FORCE_PATH_STYLE=true

# Local auth adapter
AUTH_PROVIDER=local
AUTH_SESSION_SECRET=replace-with-at-least-32-local-characters
FIELD_ENCRYPTION_KEY=replace-with-at-least-32-local-characters
FIELD_ENCRYPTION_KEY_VERSION=1

# AI/provider selection. Fake adapters require no external credentials.
AI_PROVIDER=fake
TRANSCRIPTION_PROVIDER=fake
TREND_PROVIDER=manual
AI_API_KEY=
AI_MODEL_PLANNER=fake-planner-v1
AI_MODEL_NARRATIVE=fake-narrative-v1

# YouTube OAuth — optional until real integration testing
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:4000/v1/connections/youtube/callback
YOUTUBE_DEFAULT_VISIBILITY=private

# Media and job safety limits
MAX_UPLOAD_BYTES=2147483648
UPLOAD_PART_BYTES=16777216
UPLOAD_SESSION_TTL_HOURS=24
MAX_PROJECT_ASSETS=100
MEDIA_MAX_PROCESS_SECONDS=1800
AI_REQUEST_TIMEOUT_MS=60000
AI_MAX_REPAIR_ATTEMPTS=1
SIGNED_URL_TTL_SECONDS=600
JOB_DEFAULT_TIMEOUT_MS=300000
JOB_MAX_ATTEMPTS=3
JOB_LEASE_SECONDS=60
QUEUE_PREFIX=viralforge-local
WORKER_CONCURRENCY_GENERAL=10
WORKER_CONCURRENCY_MEDIA=2

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# Product safety flags
FEATURE_PUBLIC_PUBLISHING=false
FEATURE_AUTO_DNA_APPLY=false

# Email/notifications — fake locally
NOTIFICATION_PROVIDER=fake
EMAIL_FROM=no-reply@example.invalid

# Railway injects PORT. Keep a local default only.
PORT=4000
