{
  "name": "@viralforge/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "node ./scripts/test-e2e.mjs"
  },
  "dependencies": {
    "@viralforge/observability": "workspace:*",
    "@viralforge/service-kit": "workspace:*"
  },
  "devDependencies": {
    "@viralforge/tsconfig": "workspace:*",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
